{{- $pages := where .Site.RegularPages "Section" "in" .Site.Params.mainSections -}}
{{ printf "<?xml version=\"1.0\" encoding=\"UTF-8\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ absURL "/" }}</link>
    <description>{{ with .Site.Params.description }}{{ . }}{{ else }}{{ .Site.Title }}{{ end }}</description>
    <atom:link href="{{ "index.xml" | absURL }}" rel="self" type="application/rss+xml" />
    <lastBuildDate>{{ if $pages }}{{ (index $pages 0).Date.Format "Mon, 02 Jan 2006 15:04:05 GMT" }}{{ else }}{{ now.Format "Mon, 02 Jan 2006 15:04:05 GMT" }}{{ end }}</lastBuildDate>
    <language>{{ .Site.LanguageCode }}</language>

    {{ range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <description>{{ `<![CDATA[` | safeHTML }}{{ .Summary | plainify }}{{ `]]>` | safeHTML }}</description>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 GMT" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
    </item>
    {{ end }}
  </channel>
</rss>
